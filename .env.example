# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database (PostGIS)
DATABASE_URL=postgis://gempawatch:password@db:5432/gempawatch

# Celery / Redis
REDIS_URL=redis://redis:6379/0

# No API keys needed — BMKG and USGS are both fully open, no auth

# Published host ports (override if the defaults are taken on your machine)
DB_HOST_PORT=5432
REDIS_HOST_PORT=6379
BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=3000

# Frontend
# Browser -> published backend host port; server-side render -> internal service
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://backend:8000
